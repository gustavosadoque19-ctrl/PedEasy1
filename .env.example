# ============================================
# PedEasy - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores:

# ----- Supabase (PostgreSQL) -----
SUPABASE_URL=sua-url-do-supabase
SUPABASE_ANON_KEY=sua-chave-anon

# ----- Frontend (Vite) -----
# URL da API do bot WhatsApp (opcional, fallback para localhost:3001)
VITE_BOT_API_URL=http://localhost:3001

# ----- Backend (Express porta 3000) -----
PORT=3000
JWT_SECRET=pedy-dev-secret-key-change-in-production

# CORS: origem permitida para o backend (opcional, fallback *)
CORS_ORIGIN=http://localhost:5173

# ----- reCAPTCHA -----
# Use as chaves de teste do Google para desenvolvimento (já vêm como fallback)
# VITE_RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
# RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# ----- Focus NFe -----
# Token de homologação começa com "test", token de produção com "live"
FOCUS_TOKEN=
FOCUS_CIDADE=Sao Paulo
FOCUS_UF=SP
FOCUS_API_URL=https://api.focusnfe.com.br

# ----- Bot WhatsApp (Express porta 3001) -----
BOT_API_KEY=coloque-uma-chave-secreta-aqui
CONFIG_PORT=3001
API_URL=http://localhost:3000/api

# Caminho do Chrome (opcional, detectado automaticamente)
CHROME_PATH=
