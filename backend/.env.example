# ─── Supabase ───────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── JWT ────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string

# ─── Pagar.me ───────────────────────────────
PAGARME_SECRET_KEY=ak_secret_key_here
PAGARME_PLAN_PRO=plan_pro_id
PAGARME_PLAN_ENTERPRISE=plan_enterprise_id
# Chave de assinatura do webhook (HMAC-SHA1). Obrigatória em produção.
# Obtida no painel da Pagar.me: Editora de Webhooks → Configurar → Chave de Assinatura.
PAGARME_WEBHOOK_SECRET=whsec_xxx

# ─── Server ─────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com
NODE_ENV=production

# ─── Rate Limiting ──────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Logging ────────────────────────────────
LOG_LEVEL=info
