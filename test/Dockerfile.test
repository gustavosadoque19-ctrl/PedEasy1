FROM node:22-alpine
RUN apk add --no-cache python3 make g++
WORKDIR /app
COPY backend/package*.json ./
RUN npm install --ignore-scripts && npm install better-sqlite3
COPY backend/src ./src
COPY test/sqlite-store.js ./src/store.js
COPY test/supabase-client-mock.js ./src/supabaseClient.js
COPY test/schema.sql /app/schema.sql
COPY test/init-global-db.mjs /app/init-global-db.mjs
EXPOSE 3000
CMD node /app/init-global-db.mjs && node src/index.js
